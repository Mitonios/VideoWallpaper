{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run: dotnet run",
      "type": "shell",
      "command": "dotnet",
      "args": ["run", "--project", "${workspaceFolder}/VideoWallpaper.csproj"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build: dotnet build",
      "type": "shell",
      "command": "dotnet",
      "args": ["build", "${workspaceFolder}/VideoWallpaper.csproj"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
